# =============================================================================
# threat-intel-pipeline — Environment Configuration
# Copy this to .env and fill in your values.
# All variables are prefixed with TIP_
# =============================================================================

# -----------------------------------------------------------------------------
# MISP (required for IOC storage and enrichment)
# -----------------------------------------------------------------------------
TIP_MISP_URL=http://localhost:8080
TIP_MISP_API_KEY=your-misp-api-key-here
TIP_MISP_VERIFY_SSL=false
TIP_MISP_ORG_ID=1

# -----------------------------------------------------------------------------
# AlienVault OTX (required for OTX feed)
# Free account at: https://otx.alienvault.com (takes 2 minutes)
# Get API key: My Settings → OTX Key
# -----------------------------------------------------------------------------
TIP_OTX_API_KEY=your-otx-api-key-here
TIP_OTX_PULSE_LIMIT=20
TIP_OTX_LOOKBACK_DAYS=7

# -----------------------------------------------------------------------------
# Abuse.ch — MalwareBazaar / URLhaus / ThreatFox
# Since 2024 Abuse.ch requires a FREE Auth-Key for all three APIs.
# Sign up (instant, free): https://auth.abuse.ch  →  copy your Auth-Key below.
# -----------------------------------------------------------------------------
TIP_ABUSECH_AUTH_KEY=your-abusech-auth-key-here
TIP_ABUSECH_LOOKBACK_DAYS=1

# -----------------------------------------------------------------------------
# Dedup Cache
# -----------------------------------------------------------------------------
TIP_CACHE_BACKEND=sqlite
TIP_CACHE_SQLITE_PATH=./cache/dedup.db
TIP_CACHE_TTL_DAYS=30
# For Redis backend (optional):
# TIP_CACHE_BACKEND=redis
# TIP_REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# External enrichment — VirusTotal (optional, free tier = 4 req/min)
# Free API key: https://www.virustotal.com/gui/my-apikey
# Enriches IPs, domains, URLs, and file hashes with engine detections.
# -----------------------------------------------------------------------------
TIP_VIRUSTOTAL_API_KEY=

# -----------------------------------------------------------------------------
# External enrichment — Shodan (optional)
# API key: https://account.shodan.io
# Enriches IPs with open ports, services, and known CVEs.
# -----------------------------------------------------------------------------
TIP_SHODAN_API_KEY=

# Also enrich IOCs that did NOT match MISP (uses more API quota). Default: false
TIP_EXTERNAL_ENRICH_UNMATCHED=false

# -----------------------------------------------------------------------------
# Slack (required for notifications)
# Setup: https://api.slack.com/messaging/webhooks
# -----------------------------------------------------------------------------
TIP_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
TIP_SLACK_CHANNEL=#threat-intel
TIP_SLACK_NOTIFY_ON=["high","critical"]

# -----------------------------------------------------------------------------
# Elasticsearch / Elastic SIEM (optional — Elastic Security integration)
# Leave blank to skip Elastic alert enrichment
# -----------------------------------------------------------------------------
TIP_ELASTIC_URL=http://localhost:9200
TIP_ELASTIC_USERNAME=elastic
TIP_ELASTIC_PASSWORD=changeme
TIP_ELASTIC_KIBANA_URL=http://localhost:5601
TIP_ELASTIC_ALERTS_INDEX=.alerts-security.alerts-default

# -----------------------------------------------------------------------------
# Microsoft Sentinel (optional — leave blank to skip)
# Get values from: Azure Portal → Sentinel workspace → Overview
# -----------------------------------------------------------------------------
TIP_SENTINEL_SUBSCRIPTION_ID=
TIP_SENTINEL_RESOURCE_GROUP=
TIP_SENTINEL_WORKSPACE_NAME=
# Bearer token (or leave blank to use: az account get-access-token)
TIP_SENTINEL_TOKEN=

# -----------------------------------------------------------------------------
# Scheduler intervals
# -----------------------------------------------------------------------------
TIP_OTX_SCHEDULE_MINUTES=60
TIP_ABUSECH_SCHEDULE_MINUTES=15
TIP_ENRICHMENT_SCHEDULE_MINUTES=5

# -----------------------------------------------------------------------------
# Advanced: Threat scoring weights (must sum to 1.0)
# -----------------------------------------------------------------------------
TIP_SCORING_RECENCY_WEIGHT=0.3
TIP_SCORING_CONFIDENCE_WEIGHT=0.4
TIP_SCORING_SOURCE_WEIGHT=0.3

# -----------------------------------------------------------------------------
# Advanced: STIX 2.1 export (optional)
# -----------------------------------------------------------------------------
TIP_STIX_EXPORT_ENABLED=false
TIP_STIX_EXPORT_PATH=./exports/stix

# -----------------------------------------------------------------------------
# Advanced: Prometheus metrics (optional)
# -----------------------------------------------------------------------------
TIP_METRICS_ENABLED=false
TIP_METRICS_PORT=9090
